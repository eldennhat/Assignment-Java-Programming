<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>

<VBox spacing="10" alignment="CENTER"
      stylesheets="@style.css"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.Bai4.CalculatorController" styleClass="main-window">
    <padding>
        <Insets top="15" right="15" bottom="15" left="15"/>
    </padding>

    <TextField fx:id="display" text="0" editable="false" styleClass="display"/>

    <GridPane hgap="8" vgap="8" alignment="CENTER">
        <Button text="C" GridPane.columnIndex="0" GridPane.rowIndex="0" onAction="#handleClear" styleClass="btn, btn-clear"/>
        <Button text="+/-" GridPane.columnIndex="1" GridPane.rowIndex="0" styleClass="btn, btn-operator"/>
        <Button text="\%" GridPane.columnIndex="2" GridPane.rowIndex="0" styleClass="btn, btn-operator"/>
        <Button text="/" GridPane.columnIndex="3" GridPane.rowIndex="0" onAction="#handleOperator" styleClass="btn, btn-math"/>

        <Button text="7" GridPane.columnIndex="0" GridPane.rowIndex="1" onAction="#handleNumber" styleClass="btn, btn-number"/>
        <Button text="8" GridPane.columnIndex="1" GridPane.rowIndex="1" onAction="#handleNumber" styleClass="btn, btn-number"/>
        <Button text="9" GridPane.columnIndex="2" GridPane.rowIndex="1" onAction="#handleNumber" styleClass="btn, btn-number"/>
        <Button text="*" GridPane.columnIndex="3" GridPane.rowIndex="1" onAction="#handleOperator" styleClass="btn, btn-math"/>

        <Button text="4" GridPane.columnIndex="0" GridPane.rowIndex="2" onAction="#handleNumber" styleClass="btn, btn-number"/>
        <Button text="5" GridPane.columnIndex="1" GridPane.rowIndex="2" onAction="#handleNumber" styleClass="btn, btn-number"/>
        <Button text="6" GridPane.columnIndex="2" GridPane.rowIndex="2" onAction="#handleNumber" styleClass="btn, btn-number"/>
        <Button text="-" GridPane.columnIndex="3" GridPane.rowIndex="2" onAction="#handleOperator" styleClass="btn, btn-math"/>

        <Button text="1" GridPane.columnIndex="0" GridPane.rowIndex="3" onAction="#handleNumber" styleClass="btn, btn-number"/>
        <Button text="2" GridPane.columnIndex="1" GridPane.rowIndex="3" onAction="#handleNumber" styleClass="btn, btn-number"/>
        <Button text="3" GridPane.columnIndex="2" GridPane.rowIndex="3" onAction="#handleNumber" styleClass="btn, btn-number"/>
        <Button text="+" GridPane.columnIndex="3" GridPane.rowIndex="3" onAction="#handleOperator" styleClass="btn, btn-math"/>

        <Button text="0" GridPane.columnIndex="0" GridPane.rowIndex="4" GridPane.columnSpan="2" onAction="#handleNumber" styleClass="btn, btn-number, btn-zero"/>
        <Button text="." GridPane.columnIndex="2" GridPane.rowIndex="4" onAction="#handleNumber" styleClass="btn, btn-number"/>
        <Button text="=" GridPane.columnIndex="3" GridPane.rowIndex="4" onAction="#handleEqual" styleClass="btn, btn-math"/>
    </GridPane>
</VBox>
